# JWT Configuration
# IMPORTANT: Change these values in production!

# Secret key for signing JWT tokens (use a strong random value in production)
JWT_SECRET_KEY=dev-secret-key-change-in-production

# JWT algorithm (HS256 is recommended)
JWT_ALGORITHM=HS256

# Token expiration time in minutes
JWT_EXPIRE_MINUTES=30

# Database Configuration
DATABASE_URL=mysql+asyncmy://root:123456@localhost/db_on_work

# CORS – comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Rate Limiting for auth endpoints (login/register)
# Max requests per IP within the time window (seconds)
AUTH_RATE_LIMIT_MAX=20
AUTH_RATE_LIMIT_WINDOW=60

# CAPTCHA – set to "true" to enable CAPTCHA verification on login/register
# When disabled (default), captcha_token field in request body is ignored
CAPTCHA_ENABLED=false
